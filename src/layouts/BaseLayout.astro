---
import '../styles/global.css';
import { SITE_URL, SITE_NAME, GA4_ID } from '../data/tables';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  robots?: string;
  bodyDataMode?: 'mixed' | 'table';
  bodyDataTheme?: string;
  bodyDataTable?: number;
  structuredData?: Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  robots = 'index,follow',
  bodyDataMode = 'mixed',
  bodyDataTheme = 'mixed',
  bodyDataTable,
  structuredData = [],
} = Astro.props;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    <meta name="twitter:description" content={ogDescription ?? description} />
    <meta name="twitter:url" content={canonical} />

    {structuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Analytics -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
    <script define:vars={{ GA4_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA4_ID);

      window.mtimesTrack = function(eventName, params) {
        if (typeof gtag === 'function') {
          gtag('event', eventName, params || {});
        }
      };
    </script>
  </head>
  <body
    data-mode={bodyDataMode}
    data-theme={bodyDataTheme}
    data-table={bodyDataTable}
  >
    <div class="page-wrap">
      <slot />
      <footer class="site-footer">
        <nav class="footer-links" aria-label="Site">
          <a href="/about/">About</a>
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms/">Terms of Use</a>
        </nav>
        <p class="footer-meta">© {year} multiplication-times-tables.com</p>
      </footer>
    </div>
  </body>
</html>
